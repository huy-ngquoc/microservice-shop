            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Add to categoryIds" enabled="true">
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script">String existing = props.getProperty("categoryIds", "");
String newId = vars.get("newCategoryId");
if (!"NOT_FOUND".equals(newId)) {
    String updated = existing.isEmpty() ? newId : existing + "," + newId;
    props.put("categoryIds", updated);
    log.info("Added category: " + newId + " | All: " + updated);
}</stringProp>
            </JSR223PostProcessor>
            <hashTree/>
