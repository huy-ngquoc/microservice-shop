        </hashTree>
      </hashTree>

      <!-- ========== THREAD GROUP 3: UPDATERS ========== -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Updaters - Modify Products/Variants" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <intProp name="LoopController.loops">-1</intProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">${__P(updaters,5)}</stringProp>
        <stringProp name="ThreadGroup.ramp_time">20</stringProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.duration">${DURATION}</stringProp>
        <stringProp name="ThreadGroup.delay">10</stringProp>
      </ThreadGroup>
      <hashTree>
        <!-- Pick random product/variant ONCE per iteration (sampler, not preprocessor, to avoid re-rolling before each sub-sampler) -->
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Pick Random Product" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">import java.util.Random;
Random rand = new Random();
String productIds = props.getProperty("productIds", "");
String variantIds = props.getProperty("variantIds", "");

if (!productIds.isEmpty()) {
    String[] arr = productIds.split(",");
    vars.put("targetProductId", arr[rand.nextInt(arr.length)]);
} else {
    vars.put("targetProductId", "skip");
}

if (!variantIds.isEmpty()) {
    String[] arr = variantIds.split(",");
    vars.put("targetVariantId", arr[rand.nextInt(arr.length)]);
} else {
    vars.put("targetVariantId", "skip");
}

SampleResult.setIgnore();
SampleResult.setSuccessful(true);</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
        </JSR223Sampler>
        <hashTree/>

        <!-- If Controller - Only run if we have products -->
        <IfController guiclass="IfControllerPanel" testclass="IfController" testname="If Products Exist" enabled="true">
          <stringProp name="IfController.condition">${__jexl3("${targetProductId}" != "skip")}</stringProp>
          <boolProp name="IfController.evaluateAll">false</boolProp>
          <boolProp name="IfController.useExpression">true</boolProp>
        </IfController>
        <hashTree>
          <!-- Get product first to get version -->
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET /products/{id} - Get Version" enabled="true">
            <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
              <collectionProp name="Arguments.arguments"/>
            </elementProp>
            <stringProp name="HTTPSampler.path">/products/${targetProductId}</stringProp>
            <stringProp name="HTTPSampler.method">GET</stringProp>
            <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
            <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          </HTTPSamplerProxy>
          <hashTree>
            <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Extract Version" enabled="true">
              <stringProp name="JSONPostProcessor.referenceNames">productVersion</stringProp>
              <stringProp name="JSONPostProcessor.jsonPathExprs">$.version</stringProp>
              <stringProp name="JSONPostProcessor.match_numbers">1</stringProp>
              <stringProp name="JSONPostProcessor.defaultValues">0</stringProp>
            </JSONPostProcessor>
            <hashTree/>
          </hashTree>

          <!-- Update Product -->
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="PATCH /products/{id} - Update" enabled="true">
            <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
            <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
              <collectionProp name="Arguments.arguments">
                <elementProp name="" elementType="HTTPArgument">
                  <boolProp name="HTTPArgument.always_encode">false</boolProp>
                  <stringProp name="Argument.value">{
  "name": "Updated-${__threadNum}-${__time(HHmmssSSS)}",
  "expectedVersion": ${productVersion}
}</stringProp>
                  <stringProp name="Argument.metadata">=</stringProp>
                </elementProp>
              </collectionProp>
            </elementProp>
            <stringProp name="HTTPSampler.path">/products/${targetProductId}</stringProp>
            <stringProp name="HTTPSampler.method">PATCH</stringProp>
            <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
            <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          </HTTPSamplerProxy>
          <hashTree/>
        </hashTree>

        <!-- If Controller - Only run if we have variants -->
        <IfController guiclass="IfControllerPanel" testclass="IfController" testname="If Variants Exist" enabled="true">
          <stringProp name="IfController.condition">${__jexl3("${targetVariantId}" != "skip")}</stringProp>
          <boolProp name="IfController.evaluateAll">false</boolProp>
          <boolProp name="IfController.useExpression">true</boolProp>
        </IfController>
        <hashTree>
          <!-- Get variant first to get version -->
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET /variants/{id} - Get Version" enabled="true">
            <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
              <collectionProp name="Arguments.arguments"/>
            </elementProp>
            <stringProp name="HTTPSampler.path">/variants/${targetVariantId}</stringProp>
            <stringProp name="HTTPSampler.method">GET</stringProp>
            <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
            <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          </HTTPSamplerProxy>
          <hashTree>
            <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Extract Version" enabled="true">
              <stringProp name="JSONPostProcessor.referenceNames">variantVersion</stringProp>
              <stringProp name="JSONPostProcessor.jsonPathExprs">$.version</stringProp>
              <stringProp name="JSONPostProcessor.match_numbers">1</stringProp>
              <stringProp name="JSONPostProcessor.defaultValues">0</stringProp>
            </JSONPostProcessor>
            <hashTree/>
          </hashTree>

          <!-- Update Variant -->
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="PATCH /variants/{id}/info - Update" enabled="true">
            <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
            <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
              <collectionProp name="Arguments.arguments">
                <elementProp name="" elementType="HTTPArgument">
                  <boolProp name="HTTPArgument.always_encode">false</boolProp>
                  <stringProp name="Argument.value">{
  "price": ${__Random(100000,900000)},
  "version": ${variantVersion}
}</stringProp>
                  <stringProp name="Argument.metadata">=</stringProp>
                </elementProp>
              </collectionProp>
            </elementProp>
            <stringProp name="HTTPSampler.path">/variants/${targetVariantId}/info</stringProp>
            <stringProp name="HTTPSampler.method">PATCH</stringProp>
            <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
            <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          </HTTPSamplerProxy>
          <hashTree/>
        </hashTree>

        <ConstantTimer guiclass="ConstantTimerGui" testclass="ConstantTimer" testname="Think Time" enabled="true">
          <stringProp name="ConstantTimer.delay">500</stringProp>
        </ConstantTimer>
        <hashTree/>
      </hashTree>

      <!-- ========== THREAD GROUP 4: DELETERS ========== -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Deleters - Soft/Hard Delete" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <intProp name="LoopController.loops">-1</intProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">${__P(deleters,2)}</stringProp>
        <stringProp name="ThreadGroup.ramp_time">30</stringProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.duration">${DURATION}</stringProp>
        <stringProp name="ThreadGroup.delay">30</stringProp>
      </ThreadGroup>
      <hashTree>
        <!-- Pick a product to delete ONCE per iteration with synchronized claim to avoid two deleters racing on same product -->
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Pick Random Product to Delete" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">import java.util.Random;
Random rand = new Random();
String picked = "skip";

// Remove the chosen product AND its paired variant atomically so readers stop hitting the
// cascade-soft-deleted variant (which would return 404 on GET /variants/{id}).
synchronized (props) {
    String productIds = props.getProperty("productIds", "");
    String variantIds = props.getProperty("variantIds", "");

    if (!productIds.isEmpty()) {
        String[] pArr = productIds.split(",");
        String[] vArr = variantIds.isEmpty() ? new String[0] : variantIds.split(",");

        if (pArr.length > 10 &amp;&amp; vArr.length >= pArr.length) {
            int idx = rand.nextInt(pArr.length);
            picked = pArr[idx];

            StringBuilder pSb = new StringBuilder();
            StringBuilder vSb = new StringBuilder();
            for (int i = 0; i &lt; pArr.length; i++) {
                if (i != idx) {
                    if (pSb.length() > 0) { pSb.append(","); vSb.append(","); }
                    pSb.append(pArr[i]);
                    vSb.append(vArr[i]);
                }
            }
            props.put("productIds", pSb.toString());
            props.put("variantIds", vSb.toString());
        }
    }
}

vars.put("deleteProductId", picked);
SampleResult.setIgnore();
SampleResult.setSuccessful(true);</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
        </JSR223Sampler>
        <hashTree/>

        <!-- If Controller - Only delete if we have products -->
        <IfController guiclass="IfControllerPanel" testclass="IfController" testname="If Should Delete" enabled="true">
          <stringProp name="IfController.condition">${__jexl3("${deleteProductId}" != "skip")}</stringProp>
          <boolProp name="IfController.evaluateAll">false</boolProp>
          <boolProp name="IfController.useExpression">true</boolProp>
        </IfController>
        <hashTree>
          <!-- Get product version first -->
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET /products/{id} - Get Version" enabled="true">
            <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
              <collectionProp name="Arguments.arguments"/>
            </elementProp>
            <stringProp name="HTTPSampler.path">/products/${deleteProductId}</stringProp>
            <stringProp name="HTTPSampler.method">GET</stringProp>
            <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
            <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          </HTTPSamplerProxy>
          <hashTree>
            <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Extract Version" enabled="true">
              <stringProp name="JSONPostProcessor.referenceNames">deleteProductVersion</stringProp>
              <stringProp name="JSONPostProcessor.jsonPathExprs">$.version</stringProp>
              <stringProp name="JSONPostProcessor.match_numbers">1</stringProp>
              <stringProp name="JSONPostProcessor.defaultValues">0</stringProp>
            </JSONPostProcessor>
            <hashTree/>
          </hashTree>

          <!-- Soft Delete -->
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="DELETE /products/{id} - Soft Delete" enabled="true">
            <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
              <collectionProp name="Arguments.arguments"/>
            </elementProp>
            <stringProp name="HTTPSampler.path">/products/${deleteProductId}?version=${deleteProductVersion}</stringProp>
            <stringProp name="HTTPSampler.method">DELETE</stringProp>
            <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
            <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          </HTTPSamplerProxy>
          <hashTree>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Check Soft Delete Success" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">vars.put("softDeleteSuccess", prev.getResponseCode() == "204" ? "true" : "false")</stringProp>
            </JSR223PostProcessor>
            <hashTree/>
          </hashTree>

          <!-- Only proceed if soft delete succeeded -->
          <IfController guiclass="IfControllerPanel" testclass="IfController" testname="If Soft Delete Succeeded" enabled="true">
            <stringProp name="IfController.condition">${__jexl3("${softDeleteSuccess}" == "true")}</stringProp>
            <boolProp name="IfController.evaluateAll">false</boolProp>
            <boolProp name="IfController.useExpression">true</boolProp>
          </IfController>
          <hashTree>
            <!-- Get deleted product version -->
            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET /products/deleted/{id} - Get Version" enabled="true">
              <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
                <collectionProp name="Arguments.arguments"/>
              </elementProp>
              <stringProp name="HTTPSampler.path">/products/deleted/${deleteProductId}</stringProp>
              <stringProp name="HTTPSampler.method">GET</stringProp>
              <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
              <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
            </HTTPSamplerProxy>
            <hashTree>
              <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Extract Version" enabled="true">
                <stringProp name="JSONPostProcessor.referenceNames">deleteProductVersion</stringProp>
                <stringProp name="JSONPostProcessor.jsonPathExprs">$.version</stringProp>
                <stringProp name="JSONPostProcessor.match_numbers">1</stringProp>
                <stringProp name="JSONPostProcessor.defaultValues">${deleteProductVersion}</stringProp>
              </JSONPostProcessor>
              <hashTree/>
            </hashTree>

            <!-- Hard Delete -->
            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="DELETE /products/{id}/purge - Hard Delete" enabled="true">
              <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
                <collectionProp name="Arguments.arguments"/>
              </elementProp>
              <stringProp name="HTTPSampler.path">/products/${deleteProductId}/purge?version=${deleteProductVersion}</stringProp>
              <stringProp name="HTTPSampler.method">DELETE</stringProp>
              <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
              <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
            </HTTPSamplerProxy>
            <hashTree/>
          </hashTree>
        </hashTree>

        <ConstantTimer guiclass="ConstantTimerGui" testclass="ConstantTimer" testname="Think Time" enabled="true">
          <stringProp name="ConstantTimer.delay">2000</stringProp>
        </ConstantTimer>
        <hashTree/>
      </hashTree>

      <!-- ========== TEARDOWN ========== -->
      <PostThreadGroup guiclass="PostThreadGroupGui" testclass="PostThreadGroup" testname="Teardown - Cleanup" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">1</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">1</stringProp>
        <stringProp name="ThreadGroup.ramp_time">0</stringProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
      </PostThreadGroup>
      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Log Final Stats" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">String productIds = props.getProperty("productIds", "");
String variantIds = props.getProperty("variantIds", "");
String brandIds = props.getProperty("brandIds", "");
String categoryIds = props.getProperty("categoryIds", "");

int productCount = productIds.isEmpty() ? 0 : productIds.split(",").length;
int variantCount = variantIds.isEmpty() ? 0 : variantIds.split(",").length;

log.info("=== TEST COMPLETE ===");
log.info("Products remaining: " + productCount);
log.info("Variants remaining: " + variantCount);
log.info("Brands: " + brandIds);
log.info("Categories: " + categoryIds);

SampleResult.setResponseData("Test complete. Products: " + productCount + ", Variants: " + variantCount, "UTF-8");
SampleResult.setSuccessful(true);</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
        </JSR223Sampler>
        <hashTree/>

        <!-- Optional: Cleanup brands/categories (disabled by default) -->
        <LoopController guiclass="LoopControlPanel" testclass="LoopController" testname="Cleanup Brands (disabled)" enabled="false">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">1</stringProp>
        </LoopController>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Get Brand IDs" enabled="true">
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">vars.put("cleanupBrandIds", props.getProperty("brandIds", ""));</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
          <ForeachController guiclass="ForeachControlPanel" testclass="ForeachController" testname="For Each Brand" enabled="true">
            <stringProp name="ForeachController.inputVal">cleanupBrandIds</stringProp>
            <stringProp name="ForeachController.returnVal">cleanupBrandId</stringProp>
            <boolProp name="ForeachController.useSeparator">true</boolProp>
            <stringProp name="ForeachController.startIndex">0</stringProp>
            <stringProp name="ForeachController.endIndex"></stringProp>
          </ForeachController>
          <hashTree>
            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="DELETE /brands/{id}/purge" enabled="true">
              <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
                <collectionProp name="Arguments.arguments"/>
              </elementProp>
              <stringProp name="HTTPSampler.path">/brands/${cleanupBrandId}/purge</stringProp>
              <stringProp name="HTTPSampler.method">DELETE</stringProp>
              <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
              <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
            </HTTPSamplerProxy>
            <hashTree/>
          </hashTree>
        </hashTree>
      </hashTree>

      <!-- ========== LISTENERS ========== -->
      <ResultCollector guiclass="SummaryReport" testclass="ResultCollector" testname="Summary Report" enabled="true">
        <boolProp name="ResultCollector.error_logging">false</boolProp>
        <objProp>
          <name>saveConfig</name>
          <value class="SampleSaveConfiguration">
            <time>true</time>
            <latency>true</latency>
