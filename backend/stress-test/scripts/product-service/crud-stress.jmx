        <hashTree>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Log Summary" enabled="true">
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">log.info("=== SETUP COMPLETE ===");
log.info("Brands: " + props.getProperty("brandIds", ""));
log.info("Categories: " + props.getProperty("categoryIds", ""));
props.put("productIds", "");
props.put("variantIds", "");</stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>
      </hashTree>

      <!-- ========== THREAD GROUP 1: CREATORS ========== -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Writers - Create Products" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <intProp name="LoopController.loops">-1</intProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">${__P(writers,10)}</stringProp>
        <stringProp name="ThreadGroup.ramp_time">10</stringProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.duration">${DURATION}</stringProp>
        <stringProp name="ThreadGroup.delay">0</stringProp>
      </ThreadGroup>
      <hashTree>
        <!-- Get random brand/category -->
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Pick Random Brand/Category" enabled="true">
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">import java.util.Random;
Random rand = new Random();

String[] brands = props.getProperty("brandIds", "").split(",");
String[] categories = props.getProperty("categoryIds", "").split(",");

if (brands.length > 0 &amp;&amp; !brands[0].isEmpty()) {
    vars.put("brandId", brands[rand.nextInt(brands.length)]);
}
if (categories.length > 0 &amp;&amp; !categories[0].isEmpty()) {
    vars.put("categoryId", categories[rand.nextInt(categories.length)]);
}

// Random color
String[] colors = ["Black", "White", "Navy", "Gray", "Red"];
vars.put("color", colors[rand.nextInt(colors.length)]);

// Random size
String[] sizes = ["S", "M", "L", "XL"];
vars.put("size", sizes[rand.nextInt(sizes.length)]);

// Random targets
String[] genders = ["Male", "Female"];
String[] bodyTypes = ["Rectangle", "Hourglass", "Pear", "Apple", "Inverted_triangle"];
vars.put("gender", genders[rand.nextInt(genders.length)]);
vars.put("bodyType", bodyTypes[rand.nextInt(bodyTypes.length)]);</stringProp>
        </JSR223PreProcessor>
        <hashTree/>

        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST /products - Create" enabled="true">
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{
  "name": "Stress-${__threadNum}-${__counter(,)}-${__time(HHmmssSSS)}",
  "categoryId": "${categoryId}",
  "brandId": "${brandId}",
  "options": ["Size", "Color"],
  "variants": [
    {
      "price": ${__Random(100000,900000)},
      "traits": ["${size}", "${color}"],
      "targets": ["${gender}", "${bodyType}"]
    }
  ]
}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.path">/products</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Extract IDs" enabled="true">
            <stringProp name="JSONPostProcessor.referenceNames">productId;variantId</stringProp>
            <stringProp name="JSONPostProcessor.jsonPathExprs">$.id;$.variants[0].id</stringProp>
            <stringProp name="JSONPostProcessor.match_numbers">1;1</stringProp>
            <stringProp name="JSONPostProcessor.defaultValues">NOT_FOUND;NOT_FOUND</stringProp>
          </JSONPostProcessor>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Store Product/Variant IDs" enabled="true">
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">String productId = vars.get("productId");
String variantId = vars.get("variantId");

// Atomically append BOTH lists so productIds[i] and variantIds[i] always refer to the same product creation.
// This pairing lets the Deleter cascade-remove a variant when its parent product is picked for deletion.
if (!"NOT_FOUND".equals(productId) &amp;&amp; !"NOT_FOUND".equals(variantId)) {
    synchronized(props) {
        String pExisting = props.getProperty("productIds", "");
        String vExisting = props.getProperty("variantIds", "");

        String[] pIds = pExisting.isEmpty() ? new String[0] : pExisting.split(",");
        String[] vIds = vExisting.isEmpty() ? new String[0] : vExisting.split(",");

        // Truncate both together when either exceeds 500 — keep the tails aligned
        if (pIds.length > 500 || vIds.length > 500) {
            int minLen = Math.min(pIds.length, vIds.length);
            int start = Math.max(0, minLen - 400);
            StringBuilder pSb = new StringBuilder();
            StringBuilder vSb = new StringBuilder();
            for (int i = start; i &lt; minLen; i++) {
                if (pSb.length() > 0) { pSb.append(","); vSb.append(","); }
                pSb.append(pIds[i]);
                vSb.append(vIds[i]);
            }
            pExisting = pSb.toString();
            vExisting = vSb.toString();
        }

        props.put("productIds", pExisting.isEmpty() ? productId : pExisting + "," + productId);
        props.put("variantIds", vExisting.isEmpty() ? variantId : vExisting + "," + variantId);
    }
}</stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>

        <ConstantThroughputTimer guiclass="TestBeanGUI" testclass="ConstantThroughputTimer" testname="Throughput Timer" enabled="true">
          <intProp name="calcMode">2</intProp>
          <stringProp name="throughput">${__P(createRate,300)}</stringProp>
        </ConstantThroughputTimer>
        <hashTree/>
      </hashTree>

