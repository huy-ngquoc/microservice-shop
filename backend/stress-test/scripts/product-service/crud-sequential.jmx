      <hashTree>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Get Setup Properties" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">String brandId = props.get("brandId") ?: ""
String categoryId = props.get("categoryId") ?: ""
log.info("Cleanup with Brand: " + brandId + ", Category: " + categoryId)
vars.put("brandId", brandId)
vars.put("categoryId", categoryId)</stringProp>
        </JSR223PreProcessor>
        <hashTree/>

        <!-- Get Brand to get version -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET /brands/{id} - Get Brand Version" enabled="true">
